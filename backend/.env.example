APP_ENV=development

# Option 1: use a full database URL
# DATABASE_URL=mysql+pymysql://root:your-password@localhost:3306/ai_trading

# Option 2: fill MySQL fields below
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_SERVER=localhost
MYSQL_PORT=3306
MYSQL_DB=ai_trading

# If MYSQL_PASSWORD is blank and DATABASE_URL is not set, the backend falls back to SQLite.
SQLITE_DB_PATH=backend/ai_trading.db

SECRET_KEY=replace-this-with-a-long-random-secret
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: leave this blank to run in yfinance-only mode.
# In yfinance-only mode the app still works for local/demo usage without any market-data token.
UPSTOX_ACCESS_TOKEN=
UPSTOX_BASE_URL=https://api.upstox.com
UPSTOX_NSE_INSTRUMENTS_URL=https://assets.upstox.com/market-quote/instruments/exchange/NSE.json.gz
UPSTOX_BSE_INSTRUMENTS_URL=https://assets.upstox.com/market-quote/instruments/exchange/BSE.json.gz

# Optional: not required for the current default app flow.
TWELVE_DATA_API_KEY=
TWELVE_DATA_BASE_URL=https://api.twelvedata.com

# Optional: reserved for future LLM-assisted features.
LLM_API_KEY=
